# .editorconfig - 统一 Python 项目编码风格
# 根配置文件，停止向上查找其他配置
root = true

# 全局通用配置（所有文件）
[*]
# 统一使用 UTF-8 编码
charset = utf-8
# 换行符：LF（Linux/Mac 标准，Windows 自动兼容）
end_of_line = lf
# 文件末尾保留空行
insert_final_newline = true
# 去除行尾多余空格
trim_trailing_whitespace = true
# 缩进使用空格（Python 强制要求）
indent_style = space
# 全局缩进宽度 4 格（Python 官方推荐）
indent_size = 4

# Python 文件专属配置
[*.py]
# Python 官方 PEP8 规范：缩进 4 空格
indent_size = 4
# 最大行宽（PEP8 推荐 79，可根据需求改为 88/120）
max_line_length = 79
# 不使用制表符缩进
indent_style = space

# 配置文件/脚本 宽松配置
[*.{yml,yaml,json,md,sh}]
indent_size = 2
trim_trailing_whitespace = false

[Makefile]
# Makefile 必须使用制表符，强制配置
indent_style = tab